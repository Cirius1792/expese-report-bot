# Expense Report Bot — Compose interpolation variables only
#
# This file is used ONLY for docker compose variable interpolation
# (--env-file .env.deploy). The variables here are substituted into
# docker-compose.yml at startup — they are NOT passed to the container.
#
# Runtime environment variables (credentials, paths) go in .env:
#   cp .env.example .env
#   # Edit .env with your actual TELEGRAM_BOT_TOKEN, LLM_*, etc.

# === Required: File ownership (for bind-mounted database) ===
# The container runs as this UID:GID so the SQLite file on the host
# is owned by the correct user. Defaults to 1000:1000.
UID=1000
GID=1000

# === Docker authorization guidance (these go in .env, NOT here) ===
# Put both of the following in .env so the running container sees them:
#
#   AUTHORIZED_USERS_CONFIG_PATH=/data/authorized-users.json
#   UNAUTHORIZED_LOG_PATH=/data/unauthorized.log
#
# Place the whitelist file in ./data/ on the host so it maps to /data/
# inside the container. See .env.example for full documentation.
