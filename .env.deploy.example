# Expense Report Bot — Deployment Environment
# Copy this file to .env.deploy and fill in your values:
#   cp .env.deploy.example .env.deploy

# === Required ===

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# LLM API access (OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# === File ownership (for bind-mounted database) ===
# The container runs as this UID:GID so the SQLite file on the host
# is owned by the correct user. Defaults to 1000:1000.
UID=1000
GID=1000
