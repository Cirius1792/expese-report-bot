# Expense Report Bot — Environment Variables
# Copy this file to .env and fill in your values

# === Required ===

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# LLM API access (OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# === Optional ===

# SQLite database path (defaults to expenses.db if not set)
# EXPENSE_DB_PATH=expenses.db
